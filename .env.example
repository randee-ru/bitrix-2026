# Опционально для make bootstrap (передаются make-у, не docker-compose):
# make bootstrap ENV_DOCKER_REPO=https://github.com/bitrix-tools/env-docker.git ENV_DOCKER_REF=main

# Пароли и настройки MySQL/PostgreSQL/Push задаются в docker/env-docker/.env_sql и др.
# после клонирования env-docker (см. docs/02-docker.md).
